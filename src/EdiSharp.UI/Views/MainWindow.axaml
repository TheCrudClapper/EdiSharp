<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:EdiSharp.UI.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="EdiSharp.UI.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Width="800"
		Foreground="black"
		Height="500"
		Background="#FFFAF0"
		CanResize="false"
		Icon="/Assets/avalonia-logo.ico"
		Title="EdiSharp.UI">


	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
		to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:MainWindowViewModel/>
	</Design.DataContext>


	<Grid ColumnDefinitions="250,*" RowDefinitions="95*,5*">

		<!-- LEFT PANEL -->
		<StackPanel Grid.Column="0" Margin="10" Spacing="10">
			<TextBlock Text="Input" FontSize="18" FontWeight="Bold" Foreground="black"/>

			<Button Classes="main"
					Command="{Binding PickFileCommand}"
					Content="{Binding FileName}"
					Foreground="black"/>

			<TextBlock Text="Output" FontSize="18" FontWeight="Bold" Foreground="black"/>
			<StackPanel Orientation="Horizontal">
				<RadioButton Margin="0,0,5,0" Content="JSON" GroupName="OutputType"/>
				<RadioButton Content="XML" GroupName="OutputType"/>
			</StackPanel>


			<TextBlock Text="Options" FontSize="18" FontWeight="Bold" Foreground="black"/>
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<CheckBox IsChecked="{Binding Validate}"/>
				<TextBlock Text="Validate" VerticalAlignment="Center" Margin="0,0,0,1"/>
			</StackPanel>

			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<CheckBox IsChecked="{Binding ShowRawSegments}"/>
				<TextBlock Text="Show Raw Segments" VerticalAlignment="Center" Margin="0,0,0,1"/>
			</StackPanel>

			<Button Classes="main" Content="Parse" Command="{Binding ParseCommand}" Foreground="black"/>

		</StackPanel>

		<!-- RIGHT PANEL -->
		<TabControl Grid.Column="1" Margin="10">
			<TabItem Header="Raw" Foreground="Black">
				<TextBox AcceptsReturn="True" TextWrapping="Wrap" Foreground="black"/>
			</TabItem>

			<TabItem Header="Segments">
				<ListBox Foreground="black" />
			</TabItem>

			<TabItem Header="Tree">
				<TreeView Foreground="black"/>
			</TabItem>

			<TabItem Header="Output">
				<TextBox  AcceptsReturn="True" Foreground="black"/>
			</TabItem>
		</TabControl>

		<StackPanel Grid.ColumnSpan="2" Grid.Row="1" Background="LightGray">
			<TextBlock HorizontalAlignment="Center" Padding="2"/>
		</StackPanel>
	</Grid>

</Window>
